<?xml version="1.0" encoding="utf-8"?>
<!-- Framework-dependent, Windows x64: native dotnet-uptime.exe launcher + dlls.
     Requires the .NET 10 runtime installed; platform-specific.
     Produces bin/Release/net10.0/publish/fxdependent-win-x64/dotnet-uptime.exe -->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <TargetFramework>net10.0</TargetFramework>
    <PublishProtocol>FileSystem</PublishProtocol>
    <PublishDir>bin/Release/net10.0/publish/fxdependent-win-x64/</PublishDir>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
    <PublishReadyToRun>false</PublishReadyToRun>
  </PropertyGroup>
</Project>
